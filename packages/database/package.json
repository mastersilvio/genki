{
  "name": "@genki/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts src/schema.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "migrate": "bun src/migrate.ts",
    "seed": "bun src/seed.ts",
    "generate": "drizzle-kit generate",
    "check": "drizzle-kit check"
  },
  "dependencies": {
    "@genki/config": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0"
  }
}
