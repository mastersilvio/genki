    "@genki/database": "workspace:*",
    "@genki/domain": "workspace:*",
    "@genki/logger": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "drizzle-orm": "^0.44.0",
    "elysia": "^1.3.0",
    "ioredis": "^5.6.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0"
  }
}
