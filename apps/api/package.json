    "typecheck": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/openapi": "^1.3.0",
    "@genki/config": "workspace:*",
