{
  "name": "genki",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --concurrency=1",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck --concurrency=1",
    "test": "turbo test --concurrency=1",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "db:generate": "bun --cwd packages/database drizzle-kit generate",
    "db:migrate": "bun --cwd packages/database migrate",
    "db:seed": "bun --cwd packages/database seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
